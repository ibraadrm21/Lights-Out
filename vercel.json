{
    "rewrites": [
        {
            "source": "/src/(.*)",
            "destination": "/frontend/src/$1"
        },
        {
            "source": "/api/(.*)",
            "destination": "/api/index"
        },
        {
            "source": "/(.*)",
            "destination": "/frontend/public/index.html"
        }
    ],
    "headers": [
        {
            "source": "/src/(.*).js",
            "headers": [
                {
                    "key": "Content-Type",
                    "value": "application/javascript; charset=utf-8"
                }
            ]
        }
    ]
}