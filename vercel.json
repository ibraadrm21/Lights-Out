{
    "buildCommand": "echo 'No build needed'",
    "outputDirectory": "frontend/public",
    "routes": [
        {
            "src": "/src/(.*)",
            "dest": "/src/$1"
        },
        {
            "handle": "filesystem"
        },
        {
            "src": "/(.*)",
            "dest": "/index.html"
        }
    ]
}