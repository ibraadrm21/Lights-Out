{
    "rewrites": [
        {
            "source": "/src/:path*",
            "destination": "/frontend/src/:path*"
        },
        {
            "source": "/(.*)",
            "destination": "/frontend/public/index.html"
        }
    ],
    "headers": [
        {
            "source": "/src/(.*).js",
            "headers": [
                {
                    "key": "Content-Type",
                    "value": "application/javascript"
                }
            ]
        }
    ]
}