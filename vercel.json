{
    "version": 2,
    "builds": [
        {
            "src": "api/*.py",
            "use": "@vercel/python"
        },
        {
            "src": "frontend/public/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/api/register",
            "dest": "api/auth.py"
        },
        {
            "src": "/api/login",
            "dest": "api/auth.py"
        },
        {
            "src": "/api/quiz/start",
            "dest": "api/quiz.py"
        },
        {
            "src": "/api/quiz/leaderboard",
            "dest": "api/quiz.py"
        },
        {
            "src": "/api/points/(.*)",
            "dest": "api/points.py"
        },
        {
            "src": "/api/geo/random",
            "dest": "api/geo.py"
        },
        {
            "src": "/api/translate",
            "dest": "api/translate.py"
        },
        {
            "src": "/src/(.*)",
            "dest": "/frontend/src/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/frontend/public/index.html"
        }
    ],
    "headers": [
        {
            "source": "/src/(.*).js",
            "headers": [
                {
                    "key": "Content-Type",
                    "value": "application/javascript; charset=utf-8"
                }
            ]
        }
    ],
    "env": {
        "FLASK_ENV": "production"
    }
}