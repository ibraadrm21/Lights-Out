{
    "version": 2,
    "buildCommand": "cd frontend && npm install && npm run build",
    "outputDirectory": "frontend/dist",
    "installCommand": "cd frontend && npm install",
    "builds": [
        {
            "src": "api/*.py",
            "use": "@vercel/python"
        }
    ],
    "routes": [
        {
            "src": "/api/register",
            "dest": "api/auth.py"
        },
        {
            "src": "/api/login",
            "dest": "api/auth.py"
        },
        {
            "src": "/api/quiz/start",
            "dest": "api/quiz.py"
        },
        {
            "src": "/api/quiz/adaptive",
            "dest": "api/adaptive_quiz.py"
        },
        {
            "src": "/api/quiz/leaderboard",
            "dest": "api/quiz.py"
        },
        {
            "src": "/api/points/(.*)",
            "dest": "api/points.py"
        },
        {
            "src": "/api/geo/random",
            "dest": "api/geo.py"
        },
        {
            "src": "/api/translate",
            "dest": "api/translate.py"
        },
        {
            "src": "/assets/(.*)",
            "dest": "/frontend/dist/assets/$1"
        },
        {
            "src": "/(.*\\.(js|css|png|jpg|jpeg|gif|svg|ico|webp))",
            "dest": "/frontend/dist/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/frontend/dist/index.html"
        }
    ],
    "headers": [
        {
            "source": "/assets/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        }
    ],
    "env": {
        "FLASK_ENV": "production"
    }
}